#!/bin/sh

if [ -t 1 ]; then
    CYAN="$(printf '\033[1;36m')"
    GREEN="$(printf '\033[1;32m')"
    RED="$(printf '\033[1;31m')"
    YELLOW="$(printf '\033[1;33m')"
    RESET="$(printf '\033[0m')"
else
    CYAN=""
    GREEN=""
    RED=""
    YELLOW=""
    RESET=""
fi

get_device_ip()
{
    ip -4 -o addr show dev "$1" 2>/dev/null |
        awk 'NR == 1 {
            split($4, address, "/")
            print address[1]
        }'
}

print_online()
{
    label="$1"
    details="${2:-}"

    if [ -n "$details" ]; then
        printf "  %-20s ${GREEN}Online${RESET}  %s\n" "$label:" "$details"
    else
        printf "  %-20s ${GREEN}Online${RESET}\n" "$label:"
    fi
}

print_offline()
{
    label="$1"
    printf "  %-20s ${RED}Offline${RESET}\n" "$label:"
}

print_unknown()
{
    label="$1"
    details="${2:-Unknown}"
    printf "  %-20s ${YELLOW}%s${RESET}\n" "$label:" "$details"
}

HOSTNAME_VALUE="$(cat /proc/sys/kernel/hostname 2>/dev/null || printf 'Unknown')"

MODEL="$(jsonfilter -i /etc/board.json -e '@.model.name' 2>/dev/null || true)"

[ -n "$MODEL" ] ||
    MODEL="$(
        ubus call system board 2>/dev/null |
            jsonfilter -e '@.model' 2>/dev/null || true
    )"

[ -n "$MODEL" ] || MODEL="Unknown"

UPTIME="$(
    awk '{
        total = int($1)
        days = int(total / 86400)
        hours = int((total % 86400) / 3600)
        minutes = int((total % 3600) / 60)

        if (days > 0)
            printf "%dd %dh %dm", days, hours, minutes
        else if (hours > 0)
            printf "%dh %dm", hours, minutes
        else
            printf "%dm", minutes
    }' /proc/uptime
)"

LOAD="$(
    awk '{
        printf "%s, %s, %s", $1, $2, $3
    }' /proc/loadavg
)"

MEMORY="$(
    awk '
        /MemTotal:/ {
            total = $2
        }

        /MemAvailable:/ {
            available = $2
        }

        END {
            if (available == 0)
                available = total

            used = total - available

            printf "%dMB / %dMB (%.1f%% used)",
                used / 1024,
                total / 1024,
                used * 100 / total
        }
    ' /proc/meminfo
)"

if df -h /overlay >/dev/null 2>&1; then
    STORAGE="$(
        df -h /overlay |
            awk 'NR == 2 {
                printf "%s / %s (%s used)", $3, $2, $5
            }'
    )"
else
    STORAGE="$(
        df -h / |
            awk 'NR == 2 {
                printf "%s / %s (%s used)", $3, $2, $5
            }'
    )"
fi

TEMPERATURE=""

for thermal_zone in /sys/class/thermal/thermal_zone*/temp; do
    [ -r "$thermal_zone" ] || continue

    raw_temperature="$(cat "$thermal_zone" 2>/dev/null || true)"

    case "$raw_temperature" in
        ''|*[!0-9]*)
            continue
            ;;
    esac

    TEMPERATURE="$(
        awk -v temp="$raw_temperature" \
            'BEGIN { printf "%.1f°C", temp / 1000 }'
    )"

    break
done

printf "${CYAN}[System Status]${RESET}\n"
printf "  %-20s %s\n" "Hostname:" "$HOSTNAME_VALUE"
printf "  %-20s %s\n" "Model:" "$MODEL"
printf "  %-20s %s\n" "Uptime:" "$UPTIME"
printf "  %-20s %s\n" "Load:" "$LOAD"
printf "  %-20s %s\n" "Memory:" "$MEMORY"
printf "  %-20s %s\n" "Storage:" "$STORAGE"

[ -n "$TEMPERATURE" ] &&
    printf "  %-20s %s\n" "Temperature:" "$TEMPERATURE"

printf "\n${CYAN}[Network Verification]${RESET}\n"

LAN_STATUS="$(ubus call network.interface.lan status 2>/dev/null || true)"

LAN_UP="$(
    printf '%s' "$LAN_STATUS" |
        jsonfilter -e '@.up' 2>/dev/null || true
)"

LAN_DEVICE="$(
    printf '%s' "$LAN_STATUS" |
        jsonfilter -e '@.l3_device' 2>/dev/null || true
)"

LAN_IP="$(
    printf '%s' "$LAN_STATUS" |
        jsonfilter -e '@["ipv4-address"][0].address' 2>/dev/null || true
)"

[ -n "$LAN_DEVICE" ] || LAN_DEVICE="br-lan"
[ -n "$LAN_IP" ] || LAN_IP="$(get_device_ip "$LAN_DEVICE")"

if [ "$LAN_UP" = "true" ] || [ -n "$LAN_IP" ]; then
    print_online "LAN" "${LAN_IP:-No IPv4} via $LAN_DEVICE"
else
    print_offline "LAN"
fi

WAN_STATUS="$(ubus call network.interface.wan status 2>/dev/null || true)"

WAN_UP="$(
    printf '%s' "$WAN_STATUS" |
        jsonfilter -e '@.up' 2>/dev/null || true
)"

WAN_DEVICE="$(
    printf '%s' "$WAN_STATUS" |
        jsonfilter -e '@.l3_device' 2>/dev/null || true
)"

WAN_IP="$(
    printf '%s' "$WAN_STATUS" |
        jsonfilter -e '@["ipv4-address"][0].address' 2>/dev/null || true
)"

WAN_GATEWAY="$(
    printf '%s' "$WAN_STATUS" |
        jsonfilter -e '@.route[@.target="0.0.0.0"].nexthop' 2>/dev/null |
        head -n 1
)"

WAN_PROTO="$(uci -q get network.wan.proto 2>/dev/null || true)"

if [ "$WAN_UP" = "true" ]; then
    WAN_DETAILS="${WAN_IP:-No IPv4}"

    [ -n "$WAN_DEVICE" ] &&
        WAN_DETAILS="$WAN_DETAILS via $WAN_DEVICE"

    [ -n "$WAN_PROTO" ] &&
        WAN_DETAILS="$WAN_DETAILS [$WAN_PROTO]"

    print_online "WAN" "$WAN_DETAILS"
else
    print_offline "WAN"
fi

if [ -n "$WAN_GATEWAY" ]; then
    printf "  %-20s %s\n" "WAN Gateway:" "$WAN_GATEWAY"
fi

if ping -c 1 -W 2 1.1.1.1 >/dev/null 2>&1; then
    print_online "Internet"
else
    print_offline "Internet"
fi

if nslookup openwrt.org 127.0.0.1 >/dev/null 2>&1; then
    print_online "DNS"
else
    print_offline "DNS"
fi

if ip link show tailscale0 >/dev/null 2>&1; then
    TAILSCALE_IP="$(get_device_ip tailscale0)"

    if [ -n "$TAILSCALE_IP" ]; then
        print_online "Tailscale" "$TAILSCALE_IP"
    else
        print_unknown "Tailscale" "Interface present, no IPv4"
    fi
else
    print_offline "Tailscale"
fi

ZEROTIER_DEVICE="$(
    ip -o link show 2>/dev/null |
        awk -F': ' '
            $2 ~ /^zt/ {
                split($2, device, "@")
                print device[1]
                exit
            }
        '
)"

if [ -n "$ZEROTIER_DEVICE" ]; then
    ZEROTIER_IP="$(get_device_ip "$ZEROTIER_DEVICE")"

    if [ -n "$ZEROTIER_IP" ]; then
        print_online "ZeroTier" "$ZEROTIER_IP via $ZEROTIER_DEVICE"
    else
        print_unknown "ZeroTier" "$ZEROTIER_DEVICE has no IPv4"
    fi
else
    print_offline "ZeroTier"
fi

if ip link show mptun0 >/dev/null 2>&1; then
    ASTROWARP_IP="$(get_device_ip mptun0)"

    if [ -n "$ASTROWARP_IP" ]; then
        print_online "AstroWarp" "$ASTROWARP_IP"
    else
        print_unknown "AstroWarp" "mptun0 has no IPv4"
    fi
else
    print_offline "AstroWarp"
fi

printf '\n'
