#!/bin/sh

RESET="$(printf '\033[0m')"
CYAN="$(printf '\033[1;36m')"
GREEN="$(printf '\033[1;32m')"
YELLOW="$(printf '\033[1;33m')"

get_ip()
{
    ip -4 -o addr show dev "$1" 2>/dev/null |
        awk 'NR == 1 {
            split($4, address, "/")
            print address[1]
        }'
}

ZEROTIER_INTERFACE="$(
    ip -o link show 2>/dev/null |
        awk -F': ' '
            $2 ~ /^zt/ {
                split($2, interface, "@")
                print interface[1]
                exit
            }
        '
)"

TAILSCALE_IP="$(get_ip tailscale0)"
ASTROWARP_IP="$(get_ip mptun0)"

if [ -n "$ZEROTIER_INTERFACE" ]; then
    ZEROTIER_IP="$(get_ip "$ZEROTIER_INTERFACE")"
else
    ZEROTIER_IP=""
fi

[ -n "$TAILSCALE_IP" ] || TAILSCALE_IP="No IP"
[ -n "$ZEROTIER_IP" ] || ZEROTIER_IP="No IP"
[ -n "$ASTROWARP_IP" ] || ASTROWARP_IP="No IP"

print_value()
{
    value="$1"
    width="$2"

    if [ "$value" = "No IP" ]; then
        printf "${YELLOW}%-${width}s${RESET}" "$value"
    else
        printf "${GREEN}%-${width}s${RESET}" "$value"
    fi
}

printf '%s\n' \
'-------------------------------------------------------------------------------'

printf " ${CYAN}Tailscale:${RESET} "
print_value "$TAILSCALE_IP" 15

printf " ${CYAN}ZeroTier:${RESET} "
print_value "$ZEROTIER_IP" 15

printf " ${CYAN}AstroWarp:${RESET} "
print_value "$ASTROWARP_IP" 15

printf '\n'

printf '%s\n\n' \
'-------------------------------------------------------------------------------'
